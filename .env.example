# NEXT_PUBLIC_GEMINI_API_KEY: Bắt buộc nếu bật tạo IPA (chạy trong bundle trình duyệt).
# Lấy key: https://aistudio.google.com/app/apikey — sau khi đổi, restart `npm run dev`.
NEXT_PUBLIC_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Tuỳ chọn: model Gemini cho IPA (mặc định lấy từ constants). Ví dụ: gemini-2.0-flash
# NEXT_PUBLIC_GEMINI_IPA_MODEL=""

# GEMINI_API_KEY: Dùng nếu sau này có API phía server (hiện IPA gọi từ client).
GEMINI_API_KEY=""

# BASE_PATH: Tiền tố URL khi deploy dưới subpath (ví dụ GitHub Pages).
# BASE_PATH="/your-repo-name"

# APP_URL: URL công khai của app (callback, link tuyệt đối nếu cần).
APP_URL=""

# Tắt HMR khi dev (tránh flicker trong một số môi trường): DISABLE_HMR=true
# DISABLE_HMR=""
