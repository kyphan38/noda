# Firebase Web SDK config (public values for client-side auth)
# Static export note: NEXT_PUBLIC_* values are inlined at build time (`npm run build`).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""

# Single-user allowlist (set at least one, UID preferred)
NEXT_PUBLIC_ALLOWED_USER_UID=""
NEXT_PUBLIC_ALLOWED_EMAIL=""

# BASE_PATH: Tiền tố URL khi deploy dưới subpath (ví dụ GitHub Pages).
# BASE_PATH="/your-repo-name"

# APP_URL: URL công khai của app (callback, link tuyệt đối nếu cần).
APP_URL=""

# Tắt HMR khi dev (tránh flicker trong một số môi trường): DISABLE_HMR=true
# DISABLE_HMR=""
