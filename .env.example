# Auth: SHA-256 hex of UTF-8 strings (generate with: node scripts/generate-auth-hashes.js <user> <pass>)
NEXT_PUBLIC_AUTH_USERNAME_HASH=""
NEXT_PUBLIC_AUTH_PASSWORD_HASH=""

# GitHub Gist sync (client-side token — use a PAT with gist scope only).
# Static export: NEXT_PUBLIC_* is inlined at `npm run build`; set CI secrets then rebuild for prod.
NEXT_PUBLIC_GIST_TOKEN=""
# Hex id only, or full https://gist.github.com/<user>/<id> URL
NEXT_PUBLIC_GIST_ID=""

# BASE_PATH: Tiền tố URL khi deploy dưới subpath (ví dụ GitHub Pages).
# BASE_PATH="/your-repo-name"

# APP_URL: URL công khai của app (callback, link tuyệt đối nếu cần).
APP_URL=""

# Tắt HMR khi dev (tránh flicker trong một số môi trường): DISABLE_HMR=true
# DISABLE_HMR=""
