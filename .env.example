# Firebase Web SDK config (public values for client-side auth)
# Static export note: NEXT_PUBLIC_* values are inlined at build time (`npm run build`).
# Vercel / custom host: add the exact hostname (e.g. your-app.vercel.app) under Firebase Console →
# Authentication → Settings → Authorized domains, or Google sign-in returns auth/unauthorized-domain.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""

# Single-user allowlist (set at least one, UID preferred)
NEXT_PUBLIC_ALLOWED_USER_UID=""
NEXT_PUBLIC_ALLOWED_EMAIL=""
